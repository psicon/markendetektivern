rules_version = '2';
// Markendetektive — Firebase Storage rules.
//
// Public-read everywhere (the app shows product images without auth).
// Only the Firebase Admin SDK / Cloud Functions can write — clients
// cannot upload directly. This protects:
//   • markenprodukte/         — original brand-product photos
//   • handelsmarkenprodukte/  — original NoName-product photos
//   • productimagesclean/     — pipeline-generated WebP variants
//   • profilePictures/        — user avatars (admin-uploaded after
//                                processing through Cloud Functions)
//
// IMPORTANT: this preserves backwards compatibility with the
// production app. The original `bild` URLs in `markenprodukte/` and
// `handelsmarkenprodukte/` are read-only at the bucket level — the
// image-cleanup pipeline writes only to `productimagesclean/`.
service firebase.storage {
  match /b/{bucket}/o {
    // Cashback bon uploads — user can write + read their own bons.
    // Read access is needed so the detail screen can render the bon
    // image via getDownloadURL() — Cloud Functions still write
    // structured data via Admin SDK.
    match /cashback-uploads/{userId}/{file=**} {
      allow write: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size < 8 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*|application/pdf');
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // Default fallback — public-read, no client write (preserves
    // production behaviour for markenprodukte/, productimagesclean/, …).
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
