# Copy to .env and fill in. .env is gitignored.

# ---------------------------------------------------------------------------
# Engine 1: Gemini (LLM-based, fast, non-deterministic)
# ---------------------------------------------------------------------------
# Get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...

# ---------------------------------------------------------------------------
# Engine 2: Document AI Expense Parser (deterministic, specialized)
# ---------------------------------------------------------------------------
# Setup walkthrough in README §Document AI.
# 1) Enable Document AI API in your GCP project
# 2) Create a "Expense Parser" processor in the EU region
# 3) Copy the processor ID into the line below
GOOGLE_CLOUD_PROJECT=markendetektive-895f7
DOCUMENTAI_LOCATION=eu
DOCUMENTAI_PROCESSOR_ID=

# Auth — pick ONE of these two paths:
# (a) RECOMMENDED: run `gcloud auth application-default login` once.
#     Then DON'T set GOOGLE_APPLICATION_CREDENTIALS, the SDK auto-detects.
# (b) Service account key file:
# GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/markendetektive-895f7-ee3923910ddd.json
