{
  "expo": {
    "name": "MarkenDetektive",
    "slug": "markendetektive",
    "version": "4.5.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "markendetektivern",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "router": {
      "lazy": false
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "fonts": [
      "node_modules/@expo-google-fonts/nunito/Nunito_400Regular.ttf",
      "node_modules/@expo-google-fonts/nunito/Nunito_500Medium.ttf",
      "node_modules/@expo-google-fonts/nunito/Nunito_600SemiBold.ttf",
      "node_modules/@expo-google-fonts/nunito/Nunito_700Bold.ttf"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "de.markendetektive",
      "buildNumber": "959",
      "appleTeamId": "MZD2N2F887",
      "googleServicesFile": "./GoogleService-Info.plist",
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Diese App benötigt Zugriff auf die Kamera, um Barcodes von Produkten zu scannen und Preise zu vergleichen.",
        "NSLocationWhenInUseUsageDescription": "Diese App benötigt Zugriff auf deinen Standort, um dir lokale Angebote und Märkte in deiner Nähe zu zeigen.",
        "NSPhotoLibraryUsageDescription": "Diese App benötigt Zugriff auf deine Fotos, um dein Profilbild aus der Galerie auszuwählen."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0d8575"
      },
      "edgeToEdgeEnabled": true,
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "buildToolsVersion": "35.0.0",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCq7kOMAf65qjkZbG-futbMAL9N8NOFNi4"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "de.markendetektive",
      "googleServicesFile": "./google-services.json",
      "versionCode": 983
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-camera",
        {
          "cameraPermission": "Diese App benötigt Zugriff auf die Kamera, um Barcodes von Produkten zu scannen und Preise zu vergleichen."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Diese App benötigt Zugriff auf deine Fotos, um dein Profilbild aus der Galerie auszuwählen."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Diese App benötigt Zugriff auf deinen Standort, um dir lokale Angebote zu zeigen."
        }
      ],
      "@react-native-firebase/app",
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-9082891656550991~3669162596",
          "androidAppId": "ca-app-pub-9082891656550991~6267405772",
          "delayAppMeasurementInit": true,
          "optimizeInitialization": false,
          "optimizeAdLoading": false,
          "userTrackingUsageDescription": "Diese App verwendet Werbung zur Finanzierung. Ihre Daten werden anonymisiert verarbeitet."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "react-native-google-mobile-ads": {
      "android_app_id": "ca-app-pub-9082891656550991~6267405772",
      "ios_app_id": "ca-app-pub-9082891656550991~3669162596"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5b645e59-c337-44e5-81cd-7681b4515623"
      }
    },
    "owner": "patze1411"
  }
}
